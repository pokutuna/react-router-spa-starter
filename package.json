{
  "name": "react-router-spa-template",
  "version": "1.0.0",
  "description": "A modern SPA template with React Router v7, TypeScript, and Tailwind CSS, ready for GitHub Pages deployment",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "preview": "react-router build && vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "isbot": "^5.1.41",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@react-router/dev": "^7.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
